<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
  Version="6.0"
  ExtensionBundleId="com.autonarration.premierebridge"
  ExtensionBundleVersion="1.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.autonarration.panel" Version="1.0.0"/>
    <Extension Id="com.autonarration.import" Version="1.0.0"/>
    <Extension Id="com.autonarration.insert" Version="1.0.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- Premiere Pro 2021 (v15) through any future version -->
      <Host Name="PPRO" Version="[15.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.autonarration.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./index.html</MainPath>
          <ScriptPath>./premiere.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Enable Node.js runtime inside the panel -->
            <Parameter>--enable-nodejs</Parameter>
            <!-- Allow Node and browser APIs in the same context -->
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
          <StartOn>
            <Event>applicationActivate</Event>
          </StartOn>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Auto Narration Bridge</Menu>
          <Geometry>
            <Size>
              <Height>600</Height>
              <Width>320</Width>
            </Size>
            <MinSize>
              <Height>300</Height>
              <Width>260</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>

    <!-- Headless Extension: Import Latest -->
    <Extension Id="com.autonarration.import">
      <DispatchInfo>
        <Resources>
          <MainPath>./import_headless.html</MainPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AN: Import Latest</Menu>
          <Geometry>
            <Size>
              <Height>0</Height>
              <Width>0</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>

    <!-- Headless Extension: Insert Latest -->
    <Extension Id="com.autonarration.insert">
      <DispatchInfo>
        <Resources>
          <MainPath>./insert_headless.html</MainPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>false</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>AN: Insert Latest</Menu>
          <Geometry>
            <Size>
              <Height>0</Height>
              <Width>0</Width>
            </Size>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>

</ExtensionManifest>
